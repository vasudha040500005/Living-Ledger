# Database - SQLite for local dev (change to PostgreSQL for Vercel)
DATABASE_URL="file:./dev.db"
# For Vercel, use: DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Vendor credentials
VENDOR_EMAIL="vendor@yoursite.com"
VENDOR_PASSWORD="YourSecurePassword"
